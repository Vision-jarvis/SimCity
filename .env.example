# .env.example — Copy to .env and fill in your values

# ============ Kafka ============
KAFKA_BROKER_URL=localhost:9092
KAFKA_TOPIC=simcity_events

# ============ Reddit API ============
# Get these at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=simcity_digital_twin/1.0

# ============ YouTube ============
# Get at https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============ Neo4j (self-hosted) ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============ PostgreSQL ============
# Supabase free tier or local
DATABASE_URL=postgresql://user:password@localhost:5432/digital_twin

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ MLflow ============
MLFLOW_TRACKING_URI=http://localhost:5000

# ============ LLM (optional) ============
# Groq free tier for LLM agent inference
GROQ_API_KEY=

# ============ App ============
APP_ENV=development
SECRET_KEY=change-this-in-production
API_HOST=0.0.0.0
API_PORT=8000
