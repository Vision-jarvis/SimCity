# .env.example

# Kafka Configuration
KAFKA_BROKER_URL=localhost:9092
KAFKA_TOPIC=simcity_events

# Reddit API Credentials
# Get these by creating an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=simcity_digital_twin/1.0

# Neo4j (self-hosted)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
